<templateSet group="DBML">
  <template name="tbl" value="Table $NAME$ {&#10;  id int [pk, increment]&#10;  $END$&#10;}"
            description="Create a new DBML table" toReformat="true" toShortenFQNames="true">
    <variable name="NAME" expression="" defaultValue="&quot;table_name&quot;" alwaysStopAt="true"/>
    <context>
      <option name="DBML" value="true"/>
    </context>
  </template>

  <!-- Enum template using CDATA for perfect formatting -->
  <template name="enum" description="Create a new DBML Enum" toReformat="true"
            toShortenFQNames="true">
    <value><![CDATA[Enum $NAME$ {
  value1
  value2
  $END$
}]]></value>
    <variable name="NAME" expression="" defaultValue="&quot;enum_name&quot;" alwaysStopAt="true"/>
    <context>
      <option name="DBML" value="true"/>
    </context>
  </template>
</templateSet>